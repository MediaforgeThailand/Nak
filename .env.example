NEXT_PUBLIC_SUPABASE_URL=https://euvzhzhwlcuyrmnxvzdx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_TuKhu7ZNQLX0CQZ0NjeB-A_VFLdQvHx

# Public base URL of the deployment. Set this on Vercel to your production
# domain (e.g. https://nak.example.com) so the LINE OAuth redirect always
# returns to the right host instead of localhost. Must also be added to
# Supabase Auth → URL Configuration → Redirect URLs (as <url>/auth/callback).
NEXT_PUBLIC_SITE_URL=

# LINE OA notifications (staff-group alerts for new orders / payment slips).
# Keep real secrets in Vercel env vars only.
#   LINE_OA_ACCESS_TOKEN : Messaging API long-lived channel access token (used to push).
#   LINE_CHANNEL_SECRET  : Messaging API channel secret (verifies the webhook signature).
#   Webhook URL to set in the LINE console: <NEXT_PUBLIC_SITE_URL>/api/line/webhook
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_OA_ACCESS_TOKEN=

# Service-role key: used server-side by the LIFF login and the LINE notification
# worker (bypasses RLS). Set in Vercel only — never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: protects the /api/cron/line-outbox retry endpoint. If set, Vercel Cron
# must send "Authorization: Bearer <CRON_SECRET>" (configure in Vercel cron settings).
CRON_SECRET=

# LIFF-based LINE login (fixes iOS in-app browser login that loses cookies).
# NEXT_PUBLIC_LIFF_ID: the LIFF app id from the LINE Login channel (public).
# LINE_LOGIN_CHANNEL_ID: the LINE Login channel id, used server-side to verify
# the LIFF id_token. Both must also be set in Vercel.
NEXT_PUBLIC_LIFF_ID=
LINE_LOGIN_CHANNEL_ID=
